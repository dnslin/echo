    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.2.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.10"
