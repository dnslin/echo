# Future API bind address.
ECHO_HTTP_ADDR=:8080

# Future SQLite database path for the API service.
ECHO_DATABASE_PATH=/data/echo.sqlite3

# Future LiveKit connection and signing configuration.
ECHO_LIVEKIT_URL=wss://livekit.example.com
ECHO_LIVEKIT_API_KEY=replace-with-livekit-api-key
ECHO_LIVEKIT_API_SECRET=replace-with-livekit-api-secret

# Future room session signing secret for API-issued room session tokens.
ECHO_ROOM_SESSION_SECRET=replace-with-32-byte-secret

# Optional comma-separated WebSocket Origin allowlist for browser/WebView2 clients.
# Keep this bounded to trusted client origins; do not use a wildcard.
ECHO_WS_ORIGIN_PATTERNS=https://client.example.com

# Optional comma-separated HTTP CORS allowlist. This replaces local development defaults.
# Include the Wails origin for the desktop client; do not use a wildcard.
ECHO_HTTP_ORIGIN_PATTERNS=wails://wails.localhost,https://client.example.com

# Future server-side log directory.
ECHO_LOG_DIR=/logs
